            font-style: italic;
        }

        /* Footnote superscripts */
        .footnote-ref {
            font-family: 'Inter', sans-serif;
            font-size: 0.7rem;
            font-weight: 500;
            color: #0C87C9;
            text-decoration: none;
            vertical-align: super;
