                    </ul>
                </div>

                <!-- Footnotes -->
                <div class="footnotes" id="footnotes">
                    <h3>References</h3>

                    <div id="fn1" class="footnote-item"><span class="footnote-num">1.</span><a href="https://epoch.ai/data-insights/ai-capabilities-progress-has-sped-up" target="_blank">epoch.ai/data-insights/ai-capabilities-progress-has-sped-up</a></div>
                    <div id="fn2" class="footnote-item"><span class="footnote-num">2.</span><a href="https://hai.stanford.edu/ai-index/2025-ai-index-report" target="_blank">hai.stanford.edu/ai-index/2025-ai-index-report</a></div>
                    <div id="fn3" class="footnote-item"><span class="footnote-num">3.</span><a href="https://www.ibm.com/think/news/ai-tech-trends-predictions-2026" target="_blank">ibm.com/think/news/ai-tech-trends-predictions-2026</a></div>
                    <div id="fn4" class="footnote-item"><span class="footnote-num">4.</span><a href="https://www.nobelprize.org/prizes/chemistry/2024/press-release/" target="_blank">nobelprize.org/prizes/chemistry/2024/press-release</a></div>
                    <div id="fn5" class="footnote-item"><span class="footnote-num">5.</span><a href="https://www.nature.com/articles/s41586-021-03819-2" target="_blank">nature.com/articles/s41586-021-03819-2</a></div>
                    <div id="fn6" class="footnote-item"><span class="footnote-num">6.</span><a href="https://deepmind.google/blog/alphafold-five-years-of-impact/" target="_blank">deepmind.google/blog/alphafold-five-years-of-impact</a></div>
                    <div id="fn7" class="footnote-item"><span class="footnote-num">7.</span><a href="https://setr.stanford.edu/technology/biotechnology-synthetic-biology/2025" target="_blank">setr.stanford.edu/technology/biotechnology-synthetic-biology/2025</a></div>
                    <div id="fn8" class="footnote-item"><span class="footnote-num">8.</span><a href="https://innovativegenomics.org/news/crispr-clinical-trials-2025/" target="_blank">innovativegenomics.org/news/crispr-clinical-trials-2025</a></div>
