        /* Manifesto Typography */
        .manifesto-body {
            font-family: 'Source Serif Pro', serif;
            font-size: 1.125rem;
            line-height: 1.8;
            color: #1e293b;
        }
        .manifesto-body h2 {
            font-family: 'Source Serif Pro', serif;
            font-weight: 700;
            font-size: 1.75rem;
            color: #0f172a;
            margin-top: 3rem;
            margin-bottom: 1.25rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #e2e8f0;
