        .manifesto-body p {
            margin-bottom: 1.25rem;
        }
        .manifesto-body ul {
            margin-bottom: 1.5rem;
            padding-left: 0;
            list-style: none;
        }
        .manifesto-body li {
            margin-bottom: 1rem;
            padding-left: 1.5rem;
