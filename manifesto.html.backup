                    cardinal: '#8C1515',
                    eablue: '#0C87C9',
                    slate: '#334155',
                    dark: '#0F172A'
                }
            }
        }
    }
    </script>
    <style>
        body { margin: 0; background-color: #F8FAFC; color: #0F172A; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
