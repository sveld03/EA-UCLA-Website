            border-radius: 0 0.5rem 0.5rem 0;
        }
    </style>
</head>

<body class="antialiased font-sans bg-bg min-h-screen">
    <!-- Navigation -->
    <header class="fixed top-0 left-0 w-full z-50 glass-nav transition-all duration-300">
